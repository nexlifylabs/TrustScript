"1. %1$sClaves de comentarios no permitidas%2$s → comentario trasladado a la "
"carpeta de spam."

#. translators: 1: Settings link opening tag, 2: Settings link closing tag
#: includes/admin/review-guard.php:192
#, php-format
msgid "2. %1$sComment Moderation Keywords%2$s → review held for approval."
msgstr ""
"2. %1$sPalabras clave de moderación de comentarios%2$s → comentario "
"pendiente de aprobación."

#: includes/admin/review-guard.php:198
msgid "3. TrustScript Keyword Blocklist → review held for approval."
msgstr ""
"3. Lista de palabras clave bloqueadas de TrustScript → pendiente de "
"aprobación."

