msgstr "Необходимо для подключения интеграции к вашему магазину"

#: includes/consent-form-template.php:43
msgid "Order IDs"
msgstr "Номера заказов"

#: includes/consent-form-template.php:43
msgid ""
"Required for analytics and review verification (masked / never publicly "
