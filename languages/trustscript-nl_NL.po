#: includes/admin/review-setting.php:825
msgid "No memberships found."
msgstr "Er zijn geen lidmaatschappen gevonden."

#: includes/admin/review-setting.php:830
msgid "Review Request Timing"
msgstr "Het tijdstip van het verzoek om beoordeling"

#: includes/admin/review-setting.php:833
msgid "Send review request after:"
msgstr "Verzoek om beoordeling verzenden na:"

#: includes/admin/review-setting.php:840
msgid "7 days"
msgstr "7 dagen"

#: includes/admin/review-setting.php:842
msgid "14 days"
msgstr "14 dagen"

#: includes/admin/review-setting.php:844
msgid "30 days"
msgstr "30 dagen"

#: includes/admin/review-setting.php:848
msgid ""
"Allow members time to experience your content before requesting a review."
msgstr ""
"Geef leden de tijd om je content te bekijken voordat je om een beoordeling "
